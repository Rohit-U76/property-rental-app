# Environment Configuration Template
# Copy this to .env and fill in your actual values

# =====================================
# DATABASE CONFIGURATION
# =====================================

# MongoDB Connection String
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/property-rental-app

# For MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/property-rental-app?retryWrites=true&w=majority

# =====================================
# JWT AUTHENTICATION
# =====================================

# Secret key for JWT token signing
# Use a long, random, secure string in production
# IMPORTANT: Change this in production!
JWT_SECRET=your_super_secret_jwt_key_change_in_production_use_long_random_string

# JWT Token expiration time
# Format: number + time unit (ms, s, m, h, d)
# Examples: "24h" (24 hours), "7d" (7 days), "60m" (60 minutes)
JWT_EXPIRE=7d

# =====================================
# SERVER CONFIGURATION
# =====================================

# Server port
PORT=5000

# Node environment
# Values: development, production, test
NODE_ENV=development

# =====================================
# OPTIONAL CONFIGURATIONS
# =====================================

# API Rate Limiting (future enhancement)
# RATE_LIMIT_WINDOW=15m
# RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (future enhancement)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# File Upload Configuration (future enhancement)
# MAX_FILE_SIZE=5242880  (5MB in bytes)
# UPLOAD_PATH=./uploads

# =====================================
# USEFUL SCRIPTS FOR DEVELOPMENT
# =====================================
# Run: npm install
# Dev: npm run dev
# Prod: npm start
